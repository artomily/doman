{
  "info": {
    "name": "Wallo API v1",
    "description": "Wallo Web3 Scam Detection Platform - Base Chain API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.1.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "cronSecret",
      "value": "{{CRON_SECRET}}",
      "type": "string",
      "disabled": true
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Check API and database health status"
          },
          "response": []
        }
      ],
      "description": "System health endpoints"
    },
    {
      "name": "Address",
      "item": [
        {
          "name": "Get Address",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/address/0x4200000000000000000000000000000000010",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "address", "0x4200000000000000000000000000000000010"]
            },
            "description": "Get address details including risk score, tags, and scan history"
          },
          "response": []
        },
        {
          "name": "Get Address ENS Records",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/address/0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045/ens",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "address", "0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045", "ens"]
            },
            "description": "Get all ENS records associated with an address"
          },
          "response": []
        }
      ],
      "description": "Address lookup and management"
    },
    {
      "name": "ENS Resolution",
      "item": [
        {
          "name": "Resolve ENS Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/resolve/vitalik.eth",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "resolve", "vitalik.eth"]
            },
            "description": "Resolve an ENS name to its associated address"
          },
          "response": []
        }
      ],
      "description": "Ethereum Name Service resolution"
    },
    {
      "name": "Domain Scam Check",
      "item": [
        {
          "name": "Check Domain",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/check-domain?domain=example.com",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "check-domain"],
              "query": [
                {
                  "key": "domain",
                  "value": "example.com"
                }
              ]
            },
            "description": "Check if a domain is a known phishing/scam domain"
          },
          "response": []
        },
        {
          "name": "List Scam Domains",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/scam-domains?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "scam-domains"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get paginated list of known scam domains"
          },
          "response": []
        }
      ],
      "description": "Phishing domain detection and lookup"
    },
    {
      "name": "Scanner",
      "item": [
        {
          "name": "Scan Single Address",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/scan/0x4200000000000000000000000000000000010",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "scan", "0x4200000000000000000000000000000000010"]
            },
            "description": "Scan a contract address for potential scam patterns"
          },
          "response": []
        },
        {
          "name": "Batch Scan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"addresses\": [\n    \"0x4220000000000000000000000000000000000001\",\n    \"0x4333333333333333333333333333333333333333\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/scan-batch",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "scan-batch"]
            },
            "description": "Scan multiple addresses in one request (max 25)"
          },
          "response": []
        }
      ],
      "description": "Contract scanning and risk assessment"
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Create Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"address\": \"0x4200000000000000000000000000000000010\",\n  \"reason\": \"Suspicious token approval patterns detected\",\n  \"category\": \"SCAM\",\n  \"reporterAddress\": \"0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "report"]
            },
            "description": "Submit a new scam report"
          },
          "response": []
        },
        {
          "name": "List Reports",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get list of reports with filters"
          },
          "response": []
        },
        {
          "name": "Vote on Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"vote\": \"FOR\",\n  \"voterAddress\": \"0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/{{reportId}}/vote",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports", "{{reportId}}", "vote"]
            },
            "description": "Vote on a report (FOR or AGAINST)"
          },
          "response": []
        }
      ],
      "description": "Community reporting and voting"
    },
    {
      "name": "dApps",
      "item": [
        {
          "name": "List dApps",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dapps?page=1&limit=20&sortBy=tvl&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dapps"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "sortBy",
                  "value": "tvl"
                },
                {
                  "key": "sortOrder",
                  "value": "desc"
                }
              ]
            },
            "description": "Get list of verified dApps with filtering"
          },
          "response": []
        },
        {
          "name": "Popular dApps",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dapps?list=popular&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dapps"],
              "query": [
                {
                  "key": "list",
                  "value": "popular"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get popular dApps by TVL"
          },
          "response": []
        },
        {
          "name": "Trending dApps",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dapps?list=trending&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dapps"],
              "query": [
                {
                  "key": "list",
                  "value": "trending"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get trending dApps by scan activity"
          },
          "response": []
        }
      ],
      "description": "dApp directory and discovery"
    },
    {
      "name": "Search",
      "item": [
        {
          "name": "Search Addresses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/search?q=uniswap&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "uniswap"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Search addresses by name or address string"
          },
          "response": []
        }
      ],
      "description": "Address and domain search"
    },
    {
      "name": "Leaderboard",
      "item": [
        {
          "name": "Get Leaderboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/leaderboard?period=all&category=all&page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "leaderboard"],
              "query": [
                {
                  "key": "period",
                  "value": "all"
                },
                {
                  "key": "category",
                  "value": "all"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            },
            "description": "Get user reputation leaderboard"
          },
          "response": []
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/leaderboard/0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "leaderboard", "0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb"]
            },
            "description": "Get detailed profile for a specific user"
          },
          "response": []
        }
      ],
      "description": "User reputation and rankings"
    },
    {
      "name": "Stats",
      "item": [
        {
          "name": "Get Platform Stats",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/stats",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "stats"]
            },
            "description": "Get platform-wide statistics"
          },
          "response": []
        }
      ],
      "description": "Platform statistics"
    },
    {
      "name": "Sync",
      "item": [
        {
          "name": "Sync All Sources",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{cronSecret}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"all\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sync"]
            },
            "description": "Trigger external data sync from all sources (requires CRON_SECRET)"
          },
          "response": []
        },
        {
          "name": "Sync DeFiLlama",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{cronSecret}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"defillama\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sync"]
            },
            "description": "Sync from DeFiLlama API only"
          },
          "response": []
        },
        {
          "name": "Sync ScamSniffer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{cronSecret}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"scamsniffer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "sync"]
            },
            "description": "Sync from ScamSniffer GitHub repository"
          },
          "response": []
        }
      ],
      "description": "External data synchronization (admin only)"
    }
  ]
}
