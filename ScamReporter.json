    "rawMetadata": "{\"compiler\":{\"version\":\"0.8.24+commit.e11b9ed9\"},\"language\":\"Solidity\",\"output\":{\"abi\":[{\"inputs\":[],\"name\":\"EmptyReasonHash\",\"type\":\"error\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"address\",\"name\":\"reporter\",\"type\":\"address\"},{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"reasonHash\",\"type\":\"bytes32\"},{\"indexed\":false,\"internalType\":\"bool\",\"name\":\"isScam\",\"type\":\"bool\"}],\"name\":\"ScamReportSubmitted\",\"type\":\"event\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"reasonHash\",\"type\":\"bytes32\"},{\"internalType\":\"bool\",\"name\":\"isScam\",\"type\":\"bool\"}],\"name\":\"submitReport\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"details\":\"Zero state variables \\u2192 zero SSTORE \\u2192 ~22-24k gas per call on Base.         The reasonHash must be the keccak256 of the off-chain payload so the         Supabase listener can verify on-chain \\u2194 off-chain consistency.\",\"errors\":{\"EmptyReasonHash()\":[{\"details\":\"Reverts when `reasonHash` is the zero value, which would make the      event unverifiable against any real off-chain record.\"}]},\"events\":{\"ScamReportSubmitted(address,bytes32,bool)\":{\"params\":{\"isScam\":\"True = reporter believes target is a scam.                   Non-indexed (boolean, low cardinality \\u2014 not useful as a                   filter topic, saves one topic slot per log entry).\",\"reasonHash\":\"keccak256 of the off-chain reason payload (indexed for                   integrity checks \\u2014 fetch the hash, verify the payload).\",\"reporter\":\"Address that submitted the report (indexed for                   per-address lookups in the off-chain indexer).\"}}},\"kind\":\"dev\",\"methods\":{\"submitReport(bytes32,bool)\":{\"params\":{\"isScam\":\"True if the reporter considers the target a scam.\",\"reasonHash\":\"keccak256 of the off-chain reason payload.                    Must not be bytes32(0).\"}}},\"title\":\"ScamReporter\",\"version\":1},\"userdoc\":{\"events\":{\"ScamReportSubmitted(address,bytes32,bool)\":{\"notice\":\"Emitted for every scam-report vote.\"}},\"kind\":\"user\",\"methods\":{\"submitReport(bytes32,bool)\":{\"notice\":\"Submit a scam-report vote.\"}},\"notice\":\"Decentralized scam-report vote submission for the Wallo platform.         All data lives off-chain (Supabase); this contract is the integrity         anchor \\u2014 it proves a given (reporter, reasonHash, isScam) triple was         witnessed by the chain at a specific block.\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/ScamReporter.sol\":\"ScamReporter\"},\"evmVersion\":\"cancun\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":false,\"runs\":200},\"remappings\":[\":@openzeppelin/contracts/=lib/openzeppelin-contracts/contracts/\",\":erc4626-tests/=lib/openzeppelin-contracts/lib/erc4626-tests/\",\":forge-std/=lib/forge-std/src/\",\":halmos-cheatcodes/=lib/openzeppelin-contracts/lib/halmos-cheatcodes/src/\",\":openzeppelin-contracts/=lib/openzeppelin-contracts/\"]},\"sources\":{\"src/ScamReporter.sol\":{\"keccak256\":\"0xaf383aaf46d5c03d38d6b6672802324107f4a7ae2cbdb6aff0d279de67880ee4\",\"license\":\"UNLICENSED\",\"urls\":[\"bzz-raw://ae303fa916babf4d0092bd7ac511c12e680e2e901974750dd292fe58c34b821a\",\"dweb:/ipfs/QmPoL7cR2bc9BtoQ6ucqeXfgdvUjKVfaA1GzGUiWQ9GJm9\"]}},\"version\":1}",
